# ---- AssessBank configuration ----
# Copy to .env and fill in. NEVER commit your real .env (it is gitignored).

# Server
PORT=8080

# =============================================================================
# ACTIVE LLM PROVIDER (used by the app)
# =============================================================================
# The app currently talks to a Z.ai GLM endpoint via the OpenAI-compatible API.
# Required for item generation.
ZAI_API_KEY=your-zai-api-key
ZAI_API_URL=https://api.z.ai/api/paas/v4/chat/completions
ZAI_MODEL=glm-4.6

# Google Cloud Storage — for saving/listing item banks.
# On Cloud Run, the service account is used automatically (no key file needed).
# Locally, set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path.
GCS_BUCKET_NAME=your-gcs-bucket-name

# Optional: xAPI Learning Record Store (LRS). Leave blank to disable.
LRS_ENDPOINT=
LRS_KEY=
LRS_SECRET=


# =============================================================================
# LLM PROVIDER CATALOG (optional — fill in only the providers you use)
# =============================================================================
# Below is a reference list of the most popular LLM providers and their
# environment variables. Leave anything you don't use blank or delete it.
# Model IDs change frequently — check each provider's docs for current names.

# ---- OpenAI ----------------------------------------------------------------
# https://platform.openai.com/docs
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
OPENAI_MODEL=gpt-4o

# ---- Anthropic (Claude) ----------------------------------------------------
# https://docs.claude.com
# Latest models: claude-opus-4-8, claude-sonnet-4-6, claude-haiku-4-5-20251001, claude-fable-5
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Google Gemini (AI Studio / Generative Language API) -------------------
# https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-pro
# Alias some SDKs expect:
GOOGLE_API_KEY=your-gemini-api-key

# ---- Google Vertex AI (GCP-hosted Gemini / Claude / others) ----------------
# https://cloud.google.com/vertex-ai
# Auth via GOOGLE_APPLICATION_CREDENTIALS (service-account JSON path).
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-pro

# ---- Azure OpenAI ----------------------------------------------------------
# https://learn.microsoft.com/azure/ai-services/openai/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# ---- AWS Bedrock -----------------------------------------------------------
# https://aws.amazon.com/bedrock/
# Uses standard AWS credentials (or IAM role on AWS infrastructure).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ---- Mistral AI ------------------------------------------------------------
# https://docs.mistral.ai
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-large-latest

# ---- Cohere ----------------------------------------------------------------
# https://docs.cohere.com
COHERE_API_KEY=your-cohere-api-key
COHERE_MODEL=command-r-plus

# ---- xAI (Grok) ------------------------------------------------------------
# https://docs.x.ai  (OpenAI-compatible)
XAI_API_KEY=your-xai-api-key
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4

# ---- DeepSeek --------------------------------------------------------------
# https://platform.deepseek.com  (OpenAI-compatible)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- Groq (fast inference) -------------------------------------------------
# https://console.groq.com  (OpenAI-compatible)
GROQ_API_KEY=your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Together AI -----------------------------------------------------------
# https://docs.together.ai  (OpenAI-compatible)
TOGETHER_API_KEY=your-together-api-key
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ---- Fireworks AI ----------------------------------------------------------
# https://docs.fireworks.ai  (OpenAI-compatible)
FIREWORKS_API_KEY=your-fireworks-api-key
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# ---- Perplexity ------------------------------------------------------------
# https://docs.perplexity.ai  (OpenAI-compatible)
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar-pro

# ---- OpenRouter (multi-model gateway) --------------------------------------
# https://openrouter.ai/docs  (OpenAI-compatible)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o

# ---- Replicate -------------------------------------------------------------
# https://replicate.com/docs
REPLICATE_API_TOKEN=r8_...

# ---- Hugging Face Inference -------------------------------------------------
# https://huggingface.co/docs/api-inference
HUGGINGFACE_API_KEY=hf_...
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ---- Ollama (local, self-hosted) -------------------------------------------
# https://ollama.com  (OpenAI-compatible endpoint at /v1)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3

# ---- Z.ai (GLM) ------------------------------------------------------------
# https://z.ai  (OpenAI-compatible) — see ACTIVE provider above for the
# variables the app actually reads (ZAI_API_KEY / ZAI_API_URL / ZAI_MODEL).
